generator client {
  provider      = "prisma-client-js"
  output        = "../lib/generated/prisma"
  binaryTargets = ["native", "windows", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model attendances {
  id              BigInt   @id @default(autoincrement())
  attendance_date DateTime @db.Date
  user_id         BigInt?
  users           users?   @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "attendances_fk_users")
}

model platforms {
  id             BigInt           @id @default(autoincrement())
  name           String
  user_platforms user_platforms[]
}

model projects {
  id            BigInt          @id @default(autoincrement())
  slug          String          @unique
  title         String
  description   String
  stage         String          @default("incubacion") // incubacion | desarrollo | validacion | produccion | experimentacion
  focus_areas   String[]
  stack         String[]
  hero_image    String?
  cta_label     String?
  cta_href      String?
  start_date    DateTime?       @default(dbgenerated("CURRENT_DATE")) @db.Date
  is_archived   Boolean?        @default(false)
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt
  user_projects user_projects[]
}

model roles {
  id    BigInt  @id @default(autoincrement())
  name  String  @unique
  users users[]
}

/// Programas academicos de la Universidad Surcolombiana
model programs { 
  id    BigInt @id @default(autoincrement())
  name  String @unique
  users users[]
}

model skills {
  id          BigInt        @id @default(autoincrement())
  name        String        @unique
  user_skills user_skills[]
}

model user_platforms {
  id          BigInt     @id @default(autoincrement())
  link        String
  platform_id BigInt?
  user_id     BigInt?
  platforms   platforms? @relation(fields: [platform_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_platforms_fk_platforms")
  users       users?     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_platforms_fk_users")
}

model user_projects {
  id           BigInt    @id @default(autoincrement())
  project_id   BigInt?
  user_id      BigInt?
  is_active    Boolean?  @default(true)
  project_role String?
  projects     projects? @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_projects_fk_projects")
  users        users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_projects_fk_users")
}

model user_skills {
  id       BigInt  @id @default(autoincrement())
  skill_id BigInt?
  user_id  BigInt?
  skills   skills? @relation(fields: [skill_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_skills_fk_skills")
  users    users?  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_skills_fk_users")
}

/// Datos y detalles para usuarios y perfil
model users {
  id                    BigInt           @id @default(autoincrement())
  email                 String           @unique
  password              String
  name                  String
  last_name             String
  username              String?          @unique
  username_last_changed DateTime?
  personal_email        String?
  program_id            BigInt?
  is_active             Boolean          @default(false)
  role_id               BigInt
  motivation            String
  semester              Int
  joined_at             DateTime?        @default(now())
  attendances           attendances[]
  user_platforms        user_platforms[]
  user_projects         user_projects[]
  user_skills           user_skills[]
  roles                 roles            @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "users_roles_fk")
  programs              programs?        @relation(fields: [program_id], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "users_programs_fk")
}

/// Modelo para noticias, eventos y actualizaciones del semillero
/// Nota: lib/constants/updates.ts fue movido a _deprecated/ (sin uso activo en el codebase)
model updates {
  id            BigInt    @id @default(autoincrement())
  slug          String    @unique
  title         String
  description   String
  display_date  String    // Fecha amigable para UI (ej: "13 de agosto 2025")
  published_at  DateTime  @default(now())
  tags          String[]  // Array de tags como strings
  border_color  String    @default("#454f5e")
  href          String?   // URL externa o null para páginas internas
  is_featured   Boolean   @default(false)
  status        String    @default("published") // draft, published, archived
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
}
