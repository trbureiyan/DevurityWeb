# ============================================================
# 📋 .env.example — Copia esto a .env y rellena los valores
# Genera JWT_SECRET con: openssl rand -base64 48
# Genera JWT_SECRET en Windows con: [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(48))
# ============================================================


# ======================================
# 🌐 URLs de la aplicación
# ======================================
# Desarrollo local:
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Producción (Vercel): cambiar al dominio asignado, ej: https://devurityweb.vercel.app
# NEXT_PUBLIC_API_URL=https://your-project.vercel.app
# NEXT_PUBLIC_APP_URL=https://your-project.vercel.app


# ======================================
# 🔐 Autenticación
# ======================================
JWT_SECRET=your_jwt_secret_here


# ======================================
# 🗄️ Base de datos (PostgreSQL)
# ======================================
# Desarrollo local (sin comillas en la contraseña):
DATABASE_URL=postgresql://postgres@localhost:5432/devurity?schema=public
# Producción (Supabase pooler):
# DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:password@aws-0-region.pooler.supabase.com:5432/postgres


# ======================================
# 🗄️ Supabase Storage
# ======================================
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here


# ======================================
# 📧 Correo (Nodemailer + Gmail App Password)
# ======================================
# Guía: https://myaccount.google.com/u/0/apppasswords
SERVER_EMAIL=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
SECURE=false
EMAIL=your_email@example.com
KEY_EMAIL=your_app_password_here


# ======================================
# 🏠 Dominio local (solo dev)
# ======================================
DOMAIN_LOCAL=http://localhost:3000/


# ======================================
# 🔁 Cache de actualizaciones
# ======================================
# Usar "dev" para forzar recarga en desarrollo, "stable" en producción
NEXT_PUBLIC_UPDATES_CACHE_REV=stable